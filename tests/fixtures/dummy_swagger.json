{
  "openapi": "3.0.0",
  "info": {
    "title": "JSONPlaceholder API",
    "version": "1.0.0",
    "description": "Free fake API for testing and prototyping."
  },
  "servers": [
    {
      "url": "https://jsonplaceholder.typicode.com"
    }
  ],
  "components": {
    "securitySchemes": {}
  },
  "paths": {
    "/posts": {
      "get": {
        "summary": "Get all posts",
        "parameters": [],
        "responses": {
          "200": {
            "description": "A list of 100 posts"
          }
        }
      },
      "post": {
        "summary": "Create a new post",
        "parameters": [
          {
            "name": "title",
            "in": "body",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userId",
            "in": "body",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "The created post"
          }
        }
      }
    },
    "/posts/{id}": {
      "get": {
        "summary": "Get a specific post by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The requested post"
          }
        }
      }
    }
  }
}
