{
  "openapi": "3.0.0",
  "info": {
    "title": "Sample Pet Store App",
    "version": "1.0.1"
  },
  "servers": [
    {
      "url": "https://api.petstore.com/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "paths": {
    "/pets": {
      "get": {
        "summary": "Get all pets",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of pets"
          }
        }
      }
    }
  }
}
